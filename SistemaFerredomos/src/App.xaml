<Application x:Class="SistemaFerredomos.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:convert="clr-namespace:SistemaFerredomos.src.Converters"
             Startup="Application_Startup">

    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="/src/Styles/UIColors.xaml"/>
                <ResourceDictionary Source="/src/Styles/ButtonStyle.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- MENU BUTTON -->
            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="Margin" Value="5,2"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style x:Key="LogoutButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource MenuButtonStyle}">
                <Setter Property="Foreground" Value="#e74c3c"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <!-- CONVERTERS -->
            <convert:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <convert:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <convert:NullToBoolConverter x:Key="NullToBoolConverter"/>

        </ResourceDictionary>

    </Application.Resources>
</Application>