<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- BACKGROUNDS -->
    <SolidColorBrush x:Key="primaryBackColor1" Color="#0A0C18"/>
    <SolidColorBrush x:Key="primaryBackColor2" Color="#070E2A"/>
    <SolidColorBrush x:Key="secondaryBackColor1" Color="#070E29"/>
    <SolidColorBrush x:Key="secondaryBackColor2" Color="#04091B"/>

    <!-- BORDES -->
    <SolidColorBrush x:Key="winBorderColor1" Color="#ffffff"/>
    <SolidColorBrush x:Key="winBorderColor2" Color="#ffffff"/>
    <SolidColorBrush x:Key="winBorderColor3" Color="#ffffff"/>

    <!-- PALETA -->
    <SolidColorBrush x:Key="color1" Color="#0840DF"/>
    <SolidColorBrush x:Key="color2" Color="#784DFD"/>
    <SolidColorBrush x:Key="color3" Color="#E33E31"/>
    <SolidColorBrush x:Key="color4" Color="#FE5800"/>
    <SolidColorBrush x:Key="color5" Color="#F7BF20"/>
    <SolidColorBrush x:Key="color6" Color="#FFC047"/>
    <SolidColorBrush x:Key="color7" Color="#EF6C96"/>
    <SolidColorBrush x:Key="color8" Color="#FFC047"/>
    <SolidColorBrush x:Key="color9" Color="#07F3C0"/>
    <SolidColorBrush x:Key="color10" Color="#FBA1AA"/>

    <!-- TEXTOS -->
    <SolidColorBrush x:Key="titleColor1" Color="#ffffff"/>
    <SolidColorBrush x:Key="titleColor2" Color="#ffffff"/>
    <SolidColorBrush x:Key="titleColor3" Color="#ffffff"/>

    <SolidColorBrush x:Key="plainTextColor1" Color="#9497CD"/>
    <SolidColorBrush x:Key="plainTextColor2" Color="#7C80C2"/>
    <SolidColorBrush x:Key="plainTextColor3" Color="#7376BD"/>

    <!-- PANELES -->
    <SolidColorBrush x:Key="panelColor" Color="#200F53"/>
    <SolidColorBrush x:Key="panelOverColor" Color="#281269"/>
    <SolidColorBrush x:Key="panelActiveColor" Color="#ffffff"/>

</ResourceDictionary>