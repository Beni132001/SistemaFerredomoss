<UserControl x:Class="SistemaFerredomos.src.Views.Main.BreakdownView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource primaryBackColor2}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO -->
        <Border Grid.Column="0" Margin="10"
        Background="{StaticResource panelColor}"
        CornerRadius="10"
        Padding="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <TextBlock Text="Gestión de Desgloses"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource titleColor1}"
                   Margin="0,0,0,20"/>

                <!-- ACCIONES -->
                <Grid Grid.Row="1" Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- BOTONES GRANDES -->
                    <StackPanel Orientation="Horizontal">

                        <Button Content="➕ Nuevo"
                        Width="130"
                        Height="45"
                        FontSize="14"
                        Margin="5,0"
                        Background="{StaticResource color9}"
                        Foreground="Black"
                        Command="{Binding AddCommand}"/>

                        <Button Content="🗑 Eliminar"
                        Width="130"
                        Height="45"
                        FontSize="14"
                        Margin="5,0"
                        Background="{StaticResource color3}"
                        Foreground="White"
                        Command="{Binding DeleteCommand}"/>

                        <Button Content="📥 Exportar"
                        Width="130"
                        Height="45"
                        FontSize="14"
                        Margin="5,0"
                        Background="{StaticResource color1}"
                        Foreground="White"
                        Command="{Binding ExportCommand}"/>

                    </StackPanel>

                    <!-- BUSCADOR -->
                    <Border Grid.Column="1"
                    Background="{StaticResource secondaryBackColor1}"
                    CornerRadius="8"
                    Padding="5"
                    Margin="10,0,0,0">

                        <StackPanel Orientation="Horizontal">

                            <TextBox Width="200"
                             Height="35"
                             FontSize="13"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchOrder}"/>

                            <Button Content="🔍"
                            Width="40"
                            Height="35"
                            Background="{StaticResource color1}"
                            Foreground="White"
                            Command="{Binding LoadCommand}"/>

                        </StackPanel>
                    </Border>

                </Grid>

                <!-- TABLA -->
                <Border Grid.Row="2"
                Background="{StaticResource secondaryBackColor1}"
                CornerRadius="10"
                Padding="10">

                    <DataGrid ItemsSource="{Binding BreakdownList}"
                      SelectedItem="{Binding SelectedBreakdown}"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      Foreground="{StaticResource plainTextColor1}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource panelOverColor}"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      RowHeight="35"
                      FontSize="13">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource panelColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource titleColor1}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Height" Value="35"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Orden" Binding="{Binding OrderNumber}" Width="*"/>
                            <DataGridTextColumn Header="Perfil" Binding="{Binding ProfileName}" Width="*"/>
                            <DataGridTextColumn Header="Medida (mm)" Binding="{Binding Size}" Width="*"/>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="*"/>
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding Quantity}" Width="*"/>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Border>

            </Grid>
        </Border>

        <!-- FORMULARIO DERECHO -->
        <Border Grid.Column="1"
        Margin="10"
        Background="{StaticResource secondaryBackColor1}"
        CornerRadius="10"
        Padding="25">

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFormVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <!-- GRID en lugar de StackPanel -->
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <TextBlock Text="Nuevo Desglose"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource titleColor1}"
                   Margin="0,0,0,20"/>

                <!-- CAMPOS -->
                <Grid Grid.Row="1">

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ORDEN -->
                    <TextBlock Text="Orden"
                       Grid.Row="0"
                       Foreground="{StaticResource plainTextColor1}"
                       VerticalAlignment="Center"
                       Margin="0,10"/>

                    <ComboBox Grid.Row="0" Grid.Column="1"
                      Margin="10"
                      Height="40"
                      FontSize="14"
                      ItemsSource="{Binding PendingOrders}"
                      SelectedItem="{Binding SelectedOrder}"/>

                    <!-- PERFIL -->
                    <TextBlock Text="Perfil"
                       Grid.Row="1"
                       Foreground="{StaticResource plainTextColor1}"
                       VerticalAlignment="Center"/>

                    <ComboBox Grid.Row="1" Grid.Column="1"
                      Margin="10"
                      Height="40"
                      FontSize="14"
                      ItemsSource="{Binding ProfileList}"
                      SelectedItem="{Binding SelectedProfile}"
                      DisplayMemberPath="Name"/>

                    <!-- MEDIDA -->
                    <TextBlock Text="Medida (m)"
                       Grid.Row="2"
                       Foreground="{StaticResource plainTextColor1}"
                       VerticalAlignment="Center"/>

                    <TextBox Grid.Row="2" Grid.Column="1"
                     Margin="10"
                     Height="40"
                     FontSize="14"
                     Text="{Binding Size}"/>

                    <!-- COLOR -->
                    <TextBlock Text="Color"
                       Grid.Row="3"
                       Foreground="{StaticResource plainTextColor1}"
                       VerticalAlignment="Center"/>

                    <TextBox Grid.Row="3" Grid.Column="1"
                     Margin="10"
                     Height="40"
                     FontSize="14"
                     Text="{Binding Color}"/>

                    <!-- CANTIDAD -->
                    <TextBlock Text="Cantidad"
                       Grid.Row="4"
                       Foreground="{StaticResource plainTextColor1}"
                       VerticalAlignment="Center"/>

                    <TextBox Grid.Row="4" Grid.Column="1"
                     Margin="10"
                     Height="40"
                     FontSize="14"
                     Text="{Binding Quantity}"/>

                </Grid>

                <!-- BOTONES -->
                <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

                    <Button Content="Guardar"
                    Width="120"
                    Height="45"
                    FontSize="14"
                    Background="{StaticResource color9}"
                    Foreground="Black"
                    Margin="10,0"
                    Command="{Binding SaveCommand}"/>

                    <Button Content="Cancelar"
                    Width="120"
                    Height="45"
                    FontSize="14"
                    Background="{StaticResource color3}"
                    Foreground="White"
                    Margin="10,0"
                    Command="{Binding CancelCommand}"/>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>