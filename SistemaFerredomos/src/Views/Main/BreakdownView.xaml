<UserControl x:Class="SistemaFerredomos.src.Views.Main.BreakdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Tabla + filtros -->
            <ColumnDefinition Width="*"/>
            <!-- Formulario lateral -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fila 1: Botones de acción -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="➕ Nuevo Desglose"
                        Command="{Binding AddCommand}"
                        Width="140"/>
                <Button Content="🗑️ Eliminar"
                        Command="{Binding DeleteCommand}"
                        Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedBreakdown, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="📥 Exportar Excel"
                        Command="{Binding ExportCommand}"
                        Margin="10,0,0,0" Width="130"/>
            </StackPanel>

            <!-- Fila 2: Búsqueda por número de orden -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Buscar por orden:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchOrder, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"
                         VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Fila 3: Tabla de desgloses -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding BreakdownList}"
                      SelectedItem="{Binding SelectedBreakdown}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="# Orden"       Binding="{Binding OrderNumber}" Width="120"/>
                    <DataGridTextColumn Header="Cód. Perfil"   Binding="{Binding ProfileCode}" Width="100"/>
                    <DataGridTextColumn Header="Perfil"        Binding="{Binding ProfileName}" Width="*"/>
                    <DataGridTextColumn Header="Medida"        Binding="{Binding Size}"        Width="80"/>
                    <DataGridTextColumn Header="Color"         Binding="{Binding Color}"       Width="100"/>
                    <DataGridTextColumn Header="Cantidad"      Binding="{Binding Quantity}"    Width="80"/>
                    <DataGridTextColumn Header="Fecha"         Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Formulario lateral -->
        <Border Grid.Column="1"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Width="280"
                Margin="15,0,0,0"
                Padding="15"
                BorderThickness="1"
                BorderBrush="#CCCCCC"
                CornerRadius="6">

            <StackPanel>
                <!-- Título -->
                <TextBlock Text="NUEVO DESGLOSE"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,15"/>

                <!-- Número de orden -->
                <TextBlock Text="# Orden:"/>
                <TextBox Text="{Binding OrderNumber, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Perfil (ComboBox) -->
                <TextBlock Text="Perfil:"/>
                <ComboBox ItemsSource="{Binding ProfileList}"
                          SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberPath="Name"
                          Margin="0,4,0,10"/>

                <!-- Medida (se autocompleta del perfil, editable) -->
                <TextBlock Text="Medida (mm):"/>
                <TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Color -->
                <TextBlock Text="Color:"/>
                <TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Cantidad -->
                <TextBlock Text="Cantidad:"/>
                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,20"/>

                <!-- Botones -->
                <Button Content="💾 Guardar"
                        Command="{Binding SaveCommand}"
                        Width="120"
                        HorizontalAlignment="Left"/>
                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Width="120"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
