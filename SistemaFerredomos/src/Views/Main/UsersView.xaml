<UserControl x:Class="SistemaFerredomos.src.Views.Main.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Tabla -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="➕ Agregar Usuario"
                        Command="{Binding AddCommand}" Width="140"/>
                <Button Content="✏️ Editar"
                        Command="{Binding EditCommand}" Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🗑️ Eliminar"
                        Command="{Binding DeleteCommand}" Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToBoolConverter}}"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       Width="50"/>
                    <DataGridTextColumn Header="Nombre"   Binding="{Binding Name}"     Width="*"/>
                    <DataGridTextColumn Header="Usuario"  Binding="{Binding UserName}" Width="150"/>
                    <DataGridTextColumn Header="Tipo"     Binding="{Binding Type}"     Width="100"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                <Setter Property="Background" Value="#EAF4FB"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Grid>

        <!-- Formulario lateral -->
        <Border Grid.Column="1"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Width="260" Margin="15,0,0,0" Padding="15"
                BorderThickness="1" BorderBrush="#CCCCCC" CornerRadius="6">
            <StackPanel>

                <TextBlock Text="{Binding FormTitle}"
                           FontWeight="Bold" FontSize="14"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Nombre completo:"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <TextBlock Text="Nombre de usuario:"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <TextBlock Text="Contraseña:"/>
                <PasswordBox x:Name="PasswordInput"
                             PasswordChanged="PasswordInput_PasswordChanged"
                             Margin="0,4,0,10"/>
                <TextBlock Text="(Dejar vacío para no cambiar)"
                           FontSize="10" Foreground="Gray" Margin="0,-6,0,10"/>

                <TextBlock Text="Tipo de usuario:"/>
                <ComboBox ItemsSource="{Binding UserTypes}"
                          SelectedItem="{Binding SelectedType}"
                          Margin="0,4,0,20"/>

                <Button Content="💾 Guardar"
                        Command="{Binding SaveCommand}"
                        Width="120" HorizontalAlignment="Left"/>
                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Width="120" HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>