<UserControl x:Class="SistemaFerredomos.src.Views.Main.NewOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Nueva Orden"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- Contenido -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- CATÁLOGO IZQUIERDO -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,0,15,0">
                <StackPanel>

                    <!-- Buscar producto -->
                    <TextBlock Text="Buscar Producto" FontWeight="Bold"/>
                    <TextBox Height="28" Margin="0,4,0,6"
                             Text="{Binding SearchProductText, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGrid ItemsSource="{Binding FilteredCatalogProducts}"
                              SelectedItem="{Binding SelectedCatalogProduct}"
                              AutoGenerateColumns="False"
                              Height="180" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Precio"   Binding="{Binding SalePrice, StringFormat=C}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Content="➕ Agregar Producto"
                            Command="{Binding AddCatalogProductCommand}"
                            Margin="0,6,0,16"/>

                    <!-- Separador -->
                    <Separator Margin="0,0,0,12"/>

                    <!-- Catálogo de perfiles -->
                    <TextBlock Text="Perfiles de Aluminio" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding CatalogProfiles}"
                              SelectedItem="{Binding SelectedCatalogProfile}"
                              DisplayMemberPath="Name"
                              Height="28" Margin="0,4,0,6"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Cantidad:" FontSize="11"/>
                            <TextBox Text="{Binding ProfileQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Color:" FontSize="11"/>
                            <TextBox Text="{Binding ProfileColor, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="➕ Agregar Perfil"
                            Command="{Binding AddProfileCommand}"
                            Margin="0,0,0,0"/>

                </StackPanel>
            </ScrollViewer>

            <!-- ORDEN DERECHA -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Cliente -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Cliente"/>
                            <TextBox Width="200" Text="{Binding CustomerName}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Teléfono"/>
                            <TextBox Width="150" Text="{Binding CustomerPhone}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Productos -->
                    <TextBlock Text="Productos" FontWeight="Bold" Margin="0,0,0,4"/>
                    <DataGrid ItemsSource="{Binding OrderProducts}"
                              AutoGenerateColumns="False"
                              MaxHeight="120" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto"  Binding="{Binding Products.Name}" Width="*"/>
                            <DataGridTextColumn Header="Cant."     Binding="{Binding Quantity}"      Width="60"/>
                            <DataGridTextColumn Header="Precio"    Binding="{Binding UnitPrice, StringFormat=C}" Width="80"/>
                            <DataGridTextColumn Header="Subtotal"  Binding="{Binding Subtotal, StringFormat=C}"  Width="90"/>
                            <DataGridTemplateColumn Header="X" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="❌"
                                                Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Producción -->
                    <TextBlock Text="Producción" FontWeight="Bold" Margin="0,12,0,4"/>
                    <Button Content="➕ Agregar Producción"
                            Command="{Binding AddProductionCommand}"
                            Margin="0,0,0,4" HorizontalAlignment="Left"/>
                    <DataGrid ItemsSource="{Binding OrderProductions}"
                              AutoGenerateColumns="False"
                              MaxHeight="120" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tipo"     Binding="{Binding Production.Type}" Width="90"/>
                            <DataGridTextColumn Header="Nombre"   Binding="{Binding Production.Name}" Width="*"/>
                            <DataGridTextColumn Header="Cant."    Binding="{Binding Quantity}"         Width="60"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="90"/>
                            <DataGridTemplateColumn Header="X" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="❌"
                                                Command="{Binding DataContext.RemoveProductionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Perfiles seleccionados -->
                    <TextBlock Text="Perfiles de Aluminio" FontWeight="Bold" Margin="0,12,0,4"/>
                    <DataGrid ItemsSource="{Binding OrderProfiles}"
                              AutoGenerateColumns="False"
                              MaxHeight="120" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código"  Binding="{Binding ProfileCode}" Width="80"/>
                            <DataGridTextColumn Header="Perfil"  Binding="{Binding ProfileName}" Width="*"/>
                            <DataGridTextColumn Header="Medida"  Binding="{Binding ProfileSize}" Width="70"/>
                            <DataGridTextColumn Header="Color"   Binding="{Binding Color}"       Width="80"/>
                            <DataGridTextColumn Header="Cant."   Binding="{Binding Quantity}"    Width="60"/>
                            <DataGridTemplateColumn Header="X" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="❌"
                                                Command="{Binding DataContext.RemoveProfileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Materiales necesarios -->
                    <TextBlock Text="Materiales necesarios" FontWeight="Bold" Margin="0,12,0,4"/>
                    <DataGrid ItemsSource="{Binding RequiredMaterials}"
                              AutoGenerateColumns="False"
                              MaxHeight="100" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Material"  Binding="{Binding MaterialName}" Width="*"/>
                            <DataGridTextColumn Header="Cantidad"  Binding="{Binding Quantity}"     Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Materiales faltantes -->
                    <TextBlock Text="⚠ Material faltante"
                               Foreground="Red" FontWeight="Bold"
                               Margin="0,10,0,4"/>
                    <DataGrid ItemsSource="{Binding MissingMaterials}"
                              AutoGenerateColumns="False"
                              MaxHeight="100" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Material"  Binding="{Binding MaterialName}" Width="*"/>
                            <DataGridTextColumn Header="Faltante"  Binding="{Binding Quantity}"     Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Total y guardar -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <TextBlock Text="{Binding TotalPrice, StringFormat=Total: {0:C}}"
                       FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>
            <Button Content="💾 Guardar Orden"
                    Command="{Binding SaveOrderCommand}"
                    Width="160" Height="40"/>
        </StackPanel>
    </Grid>
</UserControl>
