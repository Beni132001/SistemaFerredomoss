<UserControl x:Class="SistemaFerredomos.src.Views.Main.NewOrdersView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 mc:Ignorable="d"
 d:DesignHeight="650" d:DesignWidth="1000">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <TextBlock Text="Nueva Orden"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- 🔹 CATALOGO -->
            <StackPanel Grid.Column="0" Margin="0,0,15,0">

                <TextBlock Text="Buscar Producto" FontWeight="Bold"/>

                <TextBox Height="30"
                         Margin="0,5,0,10"
                         Text="{Binding SearchProductText, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGrid ItemsSource="{Binding FilteredCatalogProducts}"
                          SelectedItem="{Binding SelectedCatalogProduct}"
                          AutoGenerateColumns="False"
                          Height="250"
                          CanUserAddRows="False">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Precio" Binding="{Binding SalePrice, StringFormat=C}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="➕ Agregar Producto"
                        Command="{Binding AddCatalogProductCommand}"
                        Margin="0,10,0,0"/>

            </StackPanel>

            <!-- ORDEN -->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Cliente -->
                    <RowDefinition Height="Auto"/>
                    <!-- Productos -->
                    <RowDefinition Height="Auto"/>
                    <!-- Producción -->
                    <RowDefinition Height="*"/>
                    <!-- Materiales + faltantes -->
                </Grid.RowDefinitions>

                <!-- CLIENTE -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Cliente"/>
                        <TextBox Width="200" Text="{Binding CustomerName}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Teléfono"/>
                        <TextBox Width="150" Text="{Binding CustomerPhone}"/>
                    </StackPanel>

                </StackPanel>

                <!-- PRODUCTOS -->
                <StackPanel Grid.Row="1">
                    
                    <TextBlock Text="Productos" FontWeight="Bold"/>

                    <DataGrid ItemsSource="{Binding OrderProducts}"
                              AutoGenerateColumns="False"
                              MaxHeight="130"
                              CanUserAddRows="False">

                     <!-- columnas -->
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Producto" Binding="{Binding Products.Name}" Width="*"/>
                        <DataGridTextColumn Header="Cant." Binding="{Binding Quantity}" Width="70"/>
                        <DataGridTextColumn Header="Precio" Binding="{Binding UnitPrice, StringFormat=C}" Width="90"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="100"/>

                        <!-- 🔥 BOTÓN ELIMINAR -->
                        <DataGridTemplateColumn Header="X" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="❌"
                                            Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                    </DataGrid>
                </StackPanel>

                <!-- PRODUCCIÓN -->
                <StackPanel Grid.Row="2">

                    <TextBlock Text="Producción" FontWeight="Bold" Margin="0,10,0,5"/>

                    <Button Content="➕ Agregar Producción"
                            Command="{Binding AddProductionCommand}"
                            Margin="0,0,0,5"/>

                    <DataGrid ItemsSource="{Binding OrderProductions}"
                              AutoGenerateColumns="False"
                              MaxHeight="130"
                              CanUserAddRows="False">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Tipo" Binding="{Binding Production.Type}" Width="100"/>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Production.Name}" Width="*"/>
                            <DataGridTextColumn Header="Cant." Binding="{Binding Quantity}" Width="70"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="100"/>

                            <DataGridTemplateColumn Header="X" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="❌"
                                                Command="{Binding DataContext.RemoveProductionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>

                <!-- MATERIALES -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <!-- MATERIALES -->
                        <TextBlock Text="Materiales necesarios"
                                   FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <DataGrid ItemsSource="{Binding RequiredMaterials}"
                                  AutoGenerateColumns="False"
                                  MaxHeight="150"
                                  CanUserAddRows="False">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="*"/>
                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Quantity}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 🔥 FALTANTES -->
                        <TextBlock Text="⚠ Material faltante"
                                   Foreground="Red"
                                   FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <DataGrid ItemsSource="{Binding MissingMaterials}"
                                  AutoGenerateColumns="False"
                                  MaxHeight="150"
                                  CanUserAddRows="False">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="*"/>
                                <DataGridTextColumn Header="Faltante" Binding="{Binding Quantity}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>

                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- TOTAL -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <TextBlock Text="{Binding TotalPrice, StringFormat=Total: {0:C}}"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,20,0"/>

            <Button Content="💾 Guardar Orden"
                    Command="{Binding SaveOrderCommand}"
                    Width="160"
                    Height="40"/>
        </StackPanel>

    </Grid>

</UserControl>