<UserControl x:Class="SistemaFerredomos.src.Views.Main.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Tabla -->
            <ColumnDefinition Width="*"/>
            <!-- Formulario lateral -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Botones de acción -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="➕ Agregar Perfil"
                        Command="{Binding AddCommand}"
                        Width="130"/>
                <Button Content="✏️ Editar"
                        Command="{Binding EditCommand}"
                        Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedProfile, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🗑️ Eliminar"
                        Command="{Binding DeleteCommand}"
                        Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedProfile, Converter={StaticResource NullToBoolConverter}}"/>
            </StackPanel>

            <!-- Tabla de perfiles -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ProfileList}"
                      SelectedItem="{Binding SelectedProfile}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="120"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Medida" Binding="{Binding Size}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Formulario lateral -->
        <Border Grid.Column="1"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Width="260"
                Margin="15,0,0,0"
                Padding="15"
                BorderThickness="1"
                BorderBrush="#CCCCCC"
                CornerRadius="6">

            <StackPanel>
                <!-- Título -->
                <TextBlock Text="{Binding FormTitle}"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,15"/>

                <!-- Código -->
                <TextBlock Text="Código:"/>
                <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Nombre -->
                <TextBlock Text="Nombre:"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Medida -->
                <TextBlock Text="Medida (mm):"/>
                <TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,20"/>

                <!-- Botones -->
                <Button Content="💾 Guardar"
                        Command="{Binding SaveCommand}"
                        Width="120"
                        HorizontalAlignment="Left"/>
                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Width="120"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
