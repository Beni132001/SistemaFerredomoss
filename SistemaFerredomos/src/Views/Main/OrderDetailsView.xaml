<UserControl x:Class="SistemaFerredomos.src.Views.Main.OrderDetailsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Detalle de Orden"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <DataGrid ItemsSource="{Binding Products}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding Products.Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Quantity}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Precio"
                                        Binding="{Binding UnitPrice, StringFormat=C}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>
            <!-- Producciones -->
            <TextBlock Text="Producción" FontWeight="Bold" Margin="0,0,0,6"/>
            <DataGrid ItemsSource="{Binding Productions}"
              AutoGenerateColumns="False"
              CanUserAddRows="False" IsReadOnly="True"
              MaxHeight="180">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tipo"      Binding="{Binding Production.Type}" Width="90"/>
                    <DataGridTextColumn Header="Nombre"    Binding="{Binding Production.Name}" Width="*"/>
                    <DataGridTextColumn Header="Cant."     Binding="{Binding Quantity}"        Width="60"/>
                    <DataGridTextColumn Header="Precio"    Binding="{Binding UnitPrice, StringFormat=C}" Width="90"/>
                    <DataGridTextColumn Header="Subtotal"  Binding="{Binding Subtotal, StringFormat=C}"  Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

        </StackPanel>

    </Grid>

</UserControl>