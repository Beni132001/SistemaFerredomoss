<UserControl x:Class="SistemaFerredomos.src.Views.Main.OrderDetailsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Detalle de Orden"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <DataGrid ItemsSource="{Binding Products}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding Products.Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Quantity}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Precio"
                                        Binding="{Binding UnitPrice, StringFormat=C}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

    </Grid>

</UserControl>