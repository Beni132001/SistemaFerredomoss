<UserControl x:Class="SistemaFerredomos.src.Views.Main.NewSupplierOrderView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 mc:Ignorable="d"
 d:DesignHeight="600"
 d:DesignWidth="900">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <TextBlock Text="Nuevo Pedido a Proveedor"
FontSize="22"
FontWeight="Bold"
Margin="0,0,0,15"/>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- CATALOGO MATERIALES -->
            <StackPanel Grid.Column="0" Margin="0,0,15,0">

                <TextBlock Text="Materiales disponibles"
FontWeight="Bold"/>

                <DataGrid ItemsSource="{Binding MaterialsCatalog}"
SelectedItem="{Binding SelectedMaterial}"
AutoGenerateColumns="False"
Height="250"
CanUserAddRows="False">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Material"
Binding="{Binding Name}"
Width="*"/>

                        <DataGridTextColumn Header="Stock"
Binding="{Binding Stock}"
Width="80"/>

                        <DataGridTextColumn Header="Precio"
Binding="{Binding PurchasePrice,StringFormat=C}"
Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

                <Button Content="Agregar Material"
Command="{Binding AddMaterialCommand}"
Width="160"
Height="35"
Margin="0,10,0,0"/>

            </StackPanel>

            <!-- PEDIDO -->
            <StackPanel Grid.Column="1">

                <!-- PROVEEDOR -->
                <TextBlock Text="Proveedor"/>
                <ComboBox ItemsSource="{Binding Suppliers}"
SelectedItem="{Binding SelectedSupplier}"
DisplayMemberPath="Name"
Margin="0,5,0,15"/>

                <!-- TABLA MATERIALES -->
                <TextBlock Text="Materiales del Pedido"
FontWeight="Bold"/>

                <DataGrid ItemsSource="{Binding OrderMaterials}"
AutoGenerateColumns="False"
Height="200"
CanUserAddRows="False">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Material"
Binding="{Binding Material.Name}"
Width="*"/>

                        <DataGridTextColumn Header="Cantidad"
Binding="{Binding Quantity,Mode=TwoWay}"
Width="80"/>

                        <DataGridTextColumn Header="Precio"
Binding="{Binding UnitPrice,StringFormat=C}"
Width="100"/>

                        <DataGridTextColumn Header="Subtotal"
Binding="{Binding Subtotal,StringFormat=C}"
Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>

        </Grid>

        <!-- TOTAL -->
        <StackPanel Grid.Row="2"
Orientation="Horizontal"
HorizontalAlignment="Right">

            <TextBlock Text="{Binding TotalPrice,StringFormat=Total: {0:C}}"
FontSize="18"
FontWeight="Bold"
Margin="0,0,20,0"/>

            <Button Content="Guardar Pedido"
Command="{Binding SaveOrderCommand}"
Width="160"
Height="40"/>

        </StackPanel>

    </Grid>
</UserControl>