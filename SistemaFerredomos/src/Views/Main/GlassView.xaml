<UserControl x:Class="SistemaFerredomos.src.Views.Main.GlassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Tabla -->
            <ColumnDefinition Width="*"/>
            <!-- Formulario lateral -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Botones de acción -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox Width="200" Height="28"
                         Margin="0,0,10,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Buscar por código o nombre..."/>
                <Button Content="➕ Agregar Vidrio"
                        Command="{Binding AddCommand}"
                        Width="130"/>
                <Button Content="✏️ Editar"
                        Command="{Binding EditCommand}"
                        Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedGlass, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🗑️ Eliminar"
                        Command="{Binding DeleteCommand}"
                        Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedGlass, Converter={StaticResource NullToBoolConverter}}"/>
            </StackPanel>

            <!-- Tabla de vidrios -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding GlassList}"
                      SelectedItem="{Binding SelectedGlass}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"  Binding="{Binding Code}"      Width="100"/>
                    <DataGridTextColumn Header="Nombre"  Binding="{Binding Name}"      Width="*"/>
                    <DataGridTextColumn Header="Ancho (m)"   Binding="{Binding Width}"     Width="80"/>
                    <DataGridTextColumn Header="Alto (m)"    Binding="{Binding Height}"    Width="80"/>
                    <DataGridTextColumn Header="Grosor (mm)"  Binding="{Binding Thickness}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Formulario lateral (visible solo al agregar/editar) -->
        <Border Grid.Column="1"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Width="260"
                Margin="15,0,0,0"
                Padding="15"
                BorderThickness="1"
                BorderBrush="#CCCCCC"
                CornerRadius="6">

            <StackPanel>
                <!-- Título del formulario -->
                <TextBlock Text="{Binding FormTitle}"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,15"/>

                <!-- Código -->
                <TextBlock Text="Código:"/>
                <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsCodeEditable}"
                         Margin="0,4,0,10"/>

                <!-- Nombre -->
                <TextBlock Text="Nombre:"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Ancho -->
                <TextBlock Text="Ancho (m):"/>
                <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"
                         ToolTip="Debe ser mayor a 0"/>

                <!-- Alto -->
                <TextBlock Text="Alto (m):"/>
                <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"
                         ToolTip="Debe ser mayor a 0"/>

                <!-- Grosor -->
                <TextBlock Text="Grosor (mm):"/>
                <TextBox Text="{Binding Thickness, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,20"
                         ToolTip="Debe ser mayor a 0"/>

                <!-- Botones -->
                <Button Content="💾 Guardar"
                        Command="{Binding SaveCommand}"
                        Width="120"
                        HorizontalAlignment="Left"/>
                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Width="120"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
