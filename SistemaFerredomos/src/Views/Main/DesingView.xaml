<UserControl x:Class="SistemaFerredomos.src.Views.Main.DesingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <!-- Tabla -->
            <ColumnDefinition Width="*"/>
            <!-- Vista previa -->
            <ColumnDefinition Width="200"/>
            <!-- Formulario -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Tabla -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="➕ Agregar Diseño"
                        Command="{Binding AddCommand}" Width="140"/>
                <Button Content="✏️ Editar"
                        Command="{Binding EditCommand}" Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedDesign, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="🗑️ Eliminar"
                        Command="{Binding DeleteCommand}" Margin="10,0,0,0" Width="100"
                        IsEnabled="{Binding SelectedDesign, Converter={StaticResource NullToBoolConverter}}"/>
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Designs}"
                      SelectedItem="{Binding SelectedDesign}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="50"/>
                    <DataGridTextColumn Header="Nombre"      Binding="{Binding Name}"        Width="*"/>
                    <DataGridTextColumn Header="Color"       Binding="{Binding Color}"       Width="100"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Vista previa -->
        <Border Grid.Column="1"
                Margin="10,0,0,0"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <StackPanel>
                <TextBlock Text="Vista previa"
                           FontWeight="Bold" FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <Border BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        Background="#F5F5F5"
                        Width="160" Height="160">
                    <Image Source="{Binding PreviewImage}"
                           Stretch="Uniform"
                           Margin="4"/>
                </Border>

                <!-- Info del diseño seleccionado -->
                <TextBlock Text="{Binding SelectedDesign.Name}"
                           FontWeight="Bold" FontSize="13"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,2"/>
                <TextBlock Text="{Binding SelectedDesign.Color}"
                           Foreground="#1D9E75"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding SelectedDesign.Description}"
                           Foreground="#666666"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Formulario lateral -->
        <Border Grid.Column="2"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Width="260" Margin="10,0,0,0" Padding="15"
                BorderThickness="1" BorderBrush="#CCCCCC" CornerRadius="6">
            <StackPanel>

                <TextBlock Text="{Binding FormTitle}"
                           FontWeight="Bold" FontSize="14"
                           Margin="0,0,0,15"/>

                <!-- Imagen -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                        Background="#F5F5F5"
                        Width="120" Height="120"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                    <Image Source="{Binding DesignImage}" Stretch="Uniform" Margin="4"/>
                </Border>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                    <Button Content="📷 Imagen"
                            Command="{Binding SelectImageCommand}"
                            Padding="8,4" FontSize="11"/>
                    <Button Content="✖ Quitar"
                            Command="{Binding RemoveImageCommand}"
                            Padding="8,4" FontSize="11"
                            Margin="6,0,0,0"
                            Background="#FADBD8"/>
                </StackPanel>

                <!-- Nombre -->
                <TextBlock Text="Nombre:"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Color -->
                <TextBlock Text="Color:"/>
                <TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,10"/>

                <!-- Descripción -->
                <TextBlock Text="Descripción:"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" Height="60"
                         AcceptsReturn="True"
                         Margin="0,4,0,20"/>

                <Button Content="💾 Guardar"
                        Command="{Binding SaveCommand}"
                        Width="120" HorizontalAlignment="Left"/>
                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Width="120" HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
