<UserControl x:Class="SistemaFerredomos.src.Views.Main.AddEditProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="450">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Título -->
        <TextBlock Text="{Binding Title}" Grid.Row="0" Grid.ColumnSpan="2" 
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Sección de Imagen -->
        <TextBlock Text="Imagen:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" Margin="0,10,0,0"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="5" Background="#FFF0F8FF">
            <Border BorderBrush="LightGray" BorderThickness="1" Background="White" 
                    Width="120" Height="120" HorizontalAlignment="Left">
                <Image Source="{Binding ProductImage}" 
                       Stretch="Uniform"/>
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Seleccionar Imagen" 
                        Command="{Binding SelectImageCommand}"
                        Margin="0,0,5,0" Padding="10,5" Background="#FF007ACC" Foreground="White"/>
                <Button Content="Quitar Imagen" 
                        Command="{Binding RemoveImageCommand}"
                        Background="LightCoral" Foreground="DarkRed"
                        Padding="10,5"/>
            </StackPanel>
            <TextBlock Text="{Binding ImageFileName}" 
                       FontStyle="Italic" 
                       Foreground="Gray" FontSize="10"
                       Margin="0,5,0,0" TextWrapping="Wrap"
                       MaxWidth="200"/>
        </StackPanel>

        <!-- Campos del formulario -->
        <TextBlock Text="Nombre:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,15,0,0"/>
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="2" Grid.Column="1" Margin="5,15,5,0" Height="25"/>

        <TextBlock Text="Stock:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <TextBox Text="{Binding Stock, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="3" Grid.Column="1" Margin="5,10,5,0" Height="25"/>

        <TextBlock Text="Precio Compra:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <TextBox Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="4" Grid.Column="1" Margin="5,10,5,0" Height="25"/>

        <TextBlock Text="Precio Venta:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <TextBox Text="{Binding SalePrice, UpdateSourceTrigger=PropertyChanged}" 
                 Grid.Row="5" Grid.Column="1" Margin="5,10,5,0" Height="25"/>

        <TextBlock Text="Proveedor:" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <ComboBox ItemsSource="{Binding Suppliers}"
                  SelectedItem="{Binding SelectedSupplier}"
                  DisplayMemberPath="Name"
                  Grid.Row="6" Grid.Column="1" Margin="5,10,5,0" Height="30"/>

        <!-- Botones de acción -->
        <StackPanel Orientation="Horizontal" Grid.Row="7" Grid.ColumnSpan="2" 
                    HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="Guardar" Width="80" Margin="5" 
                    Command="{Binding SaveCommand}" 
                    Background="#FF28A745" Foreground="White" FontWeight="Bold"/>
            <Button Content="Cancelar" Width="80" Margin="5" 
                    Command="{Binding CancelCommand}" 
                    Background="#FF6C757D" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</UserControl>