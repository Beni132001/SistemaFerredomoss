<UserControl x:Class="SistemaFerredomos.src.Views.Main.MaterialInventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SistemaFerredomos.src.Views.Main"
             xmlns:converters="clr-namespace:SistemaFerredomos.src.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <converters:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="LowStockRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#C62828"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <StackPanel>
            <!-- Fila superior con buscador y botón de agregar -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,10">
                <TextBox Width="200" Height="28" 
                         Margin="0,0,10,0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         ToolTip="Buscar por nombre o proveedor..."/>

                <Button Content="Agregar Material"
                        Command="{Binding AddCommand}"
                        Width="150"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"
                        x:Name="btnAgregarMaterial"/>

                <!-- Indicador de registros -->
                <TextBlock Text="{Binding RecordSummary}"
               VerticalAlignment="Center"
               Foreground="#7F8C8D"
               Margin="15,0,0,0"/>
            </StackPanel>

            <!-- DataGrid de Materiales -->
            <DataGrid x:Name="dgMaterials"
                      ItemsSource="{Binding FilteredMaterials}"
                      RowStyle="{StaticResource LowStockRowStyle}"
                      AutoGenerateColumns="False"
                      SelectedItem="{Binding SelectedMaterial}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>

                    <!-- Columna de Imagen -->
                    <DataGridTemplateColumn Header="Imagen" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Image, Converter={StaticResource ImagePathToBitmapConverter}}"
                                       Width="40" Height="40" 
                                       Stretch="Uniform"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="80"/>
                    <DataGridTextColumn x:Name="colPrecioCompra" Header="Precio Compra" Binding="{Binding PurchasePrice, StringFormat=C}" Width="100"/>
                    <DataGridTextColumn Header="Precio Venta" Binding="{Binding SalePrice, StringFormat=C}" Width="100"/>
                    <DataGridTextColumn Header="Proveedor" Binding="{Binding Supplier.Name}" Width="150"/>

                    <!-- Columna de acciones -->
                    <DataGridTemplateColumn x:Name="colAcciones" Header="Acciones" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Editar" Margin="5,0"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    
                                    <Button Content="Eliminar"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>