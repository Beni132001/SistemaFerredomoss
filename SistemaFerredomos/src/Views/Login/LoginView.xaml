<Window x:Class="SistemaFerredomos.src.Views.Login.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ferredomos — Iniciar Sesión"
        Height="480" Width="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F0">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Panel izquierdo: identidad -->
            <ColumnDefinition Width="340"/>
            <!-- Panel derecho: formulario -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO — Identidad empresa -->
        <Border Grid.Column="0" Background="#1D9E75" CornerRadius="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">

                <!-- Logo -->
                <Border Width="160" Height="160"
                        Background="White"
                        CornerRadius="80"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.15"
                                          BlurRadius="20" ShadowDepth="0"/>
                    </Border.Effect>
                    <Image Source="/src/Assets/logo.png"
                           Stretch="Uniform"
                           Margin="12"/>
                </Border>

                <!-- Nombre empresa -->
                <TextBlock Text="Ferredomos"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="de Durango"
                           Foreground="#A8E6D0"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

                <!-- Separador decorativo -->
                <Rectangle Height="2" Width="60"
                           Fill="#A8E6D0"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,20"
                           Opacity="0.6"/>

                <!-- Eslogan / descripción -->
                <TextBlock Text="Fabricación de ventanas,"
                           Foreground="#D0F0E6"
                           FontSize="12"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="domos y puertas de vidrio"
                           Foreground="#D0F0E6"
                           FontSize="12"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="y aluminio"
                           Foreground="#D0F0E6"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,0"/>

            </StackPanel>
        </Border>

        <!-- PANEL DERECHO — Formulario login -->
        <Border Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="280">

                <!-- Título -->
                <TextBlock Text="Bienvenido"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Ingresa tus credenciales para continuar"
                           FontSize="12"
                           Foreground="#95A5A6"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario" FontSize="12" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,4"/>
                <Border BorderThickness="1" CornerRadius="6" Margin="0,0,0,4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasUsernameError}" Value="True">
                                    <Setter Property="BorderBrush" Value="#E74C3C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Padding="12,10" FontSize="14"
                             Background="Transparent" VerticalContentAlignment="Center"/>
                </Border>
                <!-- Error usuario -->
                <TextBlock Text="{Binding UsernameError}"
                           Foreground="#E74C3C" FontSize="11" Margin="2,0,0,12"
                           Visibility="{Binding HasUsernameError, Converter={StaticResource BooleanToVisibilityConverter}}"/>


                <!-- Contraseña -->
                <TextBlock Text="Contraseña" FontSize="12" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,4"/>
                <Border BorderThickness="1" CornerRadius="6" Margin="0,0,0,4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPasswordError}" Value="True">
                                    <Setter Property="BorderBrush" Value="#E74C3C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <PasswordBox x:Name="PasswordBox"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 BorderThickness="0" Padding="12,10" FontSize="14"
                                 Background="Transparent" VerticalContentAlignment="Center"/>
                </Border>
                <!-- Error contraseña -->
                <TextBlock Text="{Binding PasswordError}"
                           Foreground="#E74C3C" FontSize="11" Margin="2,0,0,16"
                           Visibility="{Binding HasPasswordError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Botón Iniciar Sesión -->
                <Button Content="Iniciar Sesión"
                        Command="{Binding LoginCommand}"
                        Height="44"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#1D9E75"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,12">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0F6E56"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#B0D8CC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Mensaje de error -->
                <Border Background="#FDECEA"
                        CornerRadius="6"
                        Padding="10,8"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#C0392B"
                               FontSize="12"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </Border>

    </Grid>
</Window>
